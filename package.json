{
  "name": "autozain-system",
  "version": "0.1.0",
  "private": true,
  "description": "AutoZain — used car dealership management system (Egypt, Arabic RTL)",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build",
    "start": "npm --workspace backend run start",
    "db:migrate": "npm --workspace backend run prisma:migrate",
    "db:generate": "npm --workspace backend run prisma:generate",
    "db:seed": "npm --workspace backend run prisma:seed",
    "db:studio": "npm --workspace backend run prisma:studio",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration backend/tests/integration",
    "test:e2e": "playwright test tests/e2e",
    "test:all": "npm run test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0"
  }
}
